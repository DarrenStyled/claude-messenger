{
  "name": "claude-chat",
  "version": "1.0.0",
  "description": "Claude Chat - Private messenger",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "dist": "electron-builder --win portable"
  },
  "keywords": [],
  "author": "Claude Chat",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "peer": "^1.0.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.claudechat.app",
    "productName": "Claude Chat",
    "win": {
      "target": "portable",
      "icon": "assets/icon.png"
    },
    "portable": {
      "artifactName": "ClaudeChat.exe"
    },
    "files": [
      "main.js",
      "server.js",
      "public/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
